{
  "manifest_version": 3,
  "name": "New Tab",
  "version": "1.0",
  "description": "Redirige automatiquement vers votre page préférée",
  "permissions": ["tabs", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configurez votre page de démarrage"
    "default_icon": {
      "2048": "logo newtab.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
  "icons": {
    "512": "logo newtab.png"
  }
}
