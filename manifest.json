{
  "manifest_version": 3,
  "name": "New Tab",
  "version": "1.0",
  "description": "Redirige automatiquement vers votre page préférée",
  "permissions": ["tabs", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configurez votre page de démarrage"
   }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }

